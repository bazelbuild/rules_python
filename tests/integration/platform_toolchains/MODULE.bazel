module(name = "module_under_test")

bazel_dep(name = "rules_python", version = "0.0.0")
local_path_override(
    module_name = "rules_python",
    path = "../../..",
)

platform_runtime_repo = use_repo_rule("@rules_python//python/private:platform_runtime_repo.bzl", "platform_runtime_repo")

platform_runtime_repo(
    name = "usr_bin_python3",
    interpreter_path = "/usr/bin/python3",
)

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
use_repo(python, "rules_python_bzlmod_debug")

register_toolchains("//:all")
